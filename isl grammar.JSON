{
  "_comment": "ISL Head Movement Grammar - Alternative Version with Extended Rules",
  "_version": "1.1",
  "timing": {
    "max_sequence_gap_seconds": 2.0,
    "min_gesture_duration_seconds": 0.3,
    "sentence_break_seconds": 3.5
  },
  "single_gesture_map": {
    "NOD": "YES",
    "SHAKE": "NO",
    "TILT_LEFT": "?",
    "TILT_RIGHT": "!",
    "STATIC": ""
  },
  "sequence_map": {
    "NOD+NOD": "DEFINITELY YES",
    "SHAKE+SHAKE": "DEFINITELY NO",
    "TILT_LEFT+NOD": "REALLY?",
    "TILT_LEFT+SHAKE": "NOT SURE",
    "TILT_LEFT+TILT_LEFT": "WHY?",
    "TILT_RIGHT+NOD": "YES OF COURSE",
    "TILT_RIGHT+SHAKE": "ABSOLUTELY NOT",
    "TILT_RIGHT+TILT_RIGHT": "EMPHASIS",
    "NOD+SHAKE": "YES BUT NO",
    "SHAKE+NOD": "NO BUT YES",
    "TILT_LEFT+TILT_RIGHT": "CONFUSED",
    "TILT_RIGHT+TILT_LEFT": "THINKING"
  },
  "modifier_rules": {
    "TILT_LEFT": {
      "role": "question_marker",
      "applies_to_next": true
    },
    "TILT_RIGHT": {
      "role": "emphasis_marker",
      "applies_to_next": true
    },
    "NOD": {
      "role": "affirmation",
      "applies_to_next": false
    },
    "SHAKE": {
      "role": "negation",
      "applies_to_next": false
    }
  },
  "isl_notes": {
    "NOD": "Affirmation/agreement — pitch oscillation",
    "SHAKE": "Negation/disagreement — yaw oscillation",
    "TILT_LEFT": "Question marker / uncertainty — sustained negative roll",
    "TILT_RIGHT": "Emphasis / certainty — sustained positive roll",
    "STATIC": "Neutral — no head movement modifier"
  }
}